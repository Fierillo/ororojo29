# ==========================================
# 🗄️ DATABASE (NEON / POSTGRES)
# ==========================================
# Connection URL to your Neon.tech database
# Expected format: postgresql://user:password@host/db?sslmode=require
POSTGRES_URL=

# ==========================================
# 🔐 ADMIN PANEL SECURITY (PAYLOAD CMS)
# ==========================================
# Secret alphanumeric key used by Payload to encrypt sessions and passwords.
# In production, this should be a long random string (e.g. UUID).
PAYLOAD_SECRET=

# ==========================================
# ✉️ EMAILS (RESEND)
# ==========================================
# API key from your resend.com account to send emails from the contact form.
RESEND_API_KEY=

# ==========================================
# 🌐 WEBSITE
# ==========================================
# URL where your site is running. 
# Development: http://localhost:3000
# Production: https://www.ororojo29.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ==========================================
# ⚠️ NOTE ABOUT WHATSAPP AND CONTACT EMAILS
# ==========================================
# The WhatsApp number and contact emails (who receives messages
# from the form) are no longer configured here. They are managed
# directly from the Admin Panel in the "General Settings" section.
